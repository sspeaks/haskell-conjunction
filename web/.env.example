# Optional Cesium ion access token. Leave blank to run token-free
# (flat ellipsoid + OpenStreetMap imagery, no account required).
VITE_CESIUM_ION_TOKEN=

# Override the dev API proxy target (defaults to http://localhost:8080).
VITE_API_TARGET=http://localhost:8080

# Optional base prefix for API calls (usually empty; uses the dev proxy
# or same-origin in production).
VITE_API_BASE=

# Cap the number of satellites rendered (0 or unset = render the whole catalog).
VITE_MAX_SATS=0
